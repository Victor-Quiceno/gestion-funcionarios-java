# Archivos compilados de Java
*.class
*.war

# Ignorar .jar generados, pero NO los de lib/ (driver de PostgreSQL)
/build/**/*.jar
/target/**/*.jar

# Environment variables
.env

# Carpetas de construcción (build)
/bin/
/build/
/target/

# Archivos de configuración de IDEs (¡Muy importante ignorar esto!)
.idea/
.vscode/
*.iml
*.project
*.classpath
*.settings/

# Archivos del sistema operativo (Mac/Windows)
.DS_Store
Thumbs.db